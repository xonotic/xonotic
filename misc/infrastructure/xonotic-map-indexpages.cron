#!/bin/sh

mepwd=$PWD
me=$0

echo 19 | tee /proc/$$/autogroup || true
renice 19 $$

set -ex
cd xonotic-map-compiler/misc/infrastructure/xonotic-map-indexpages
git pull
rsync -E build-pages.sh build-index.sh style.css autobuild-bsp-uploader@beta.xonotic.org:
ssh autobuild-bsp-uploader@beta.xonotic.org 'sh build-pages.sh'
